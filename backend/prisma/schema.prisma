generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  VENDOR
  CUSTOMER
}

enum WebsiteStatus {
  ACTIVE
  DISABLED
}

enum Plan {
  STARTER
  PREMIUM
  ROYAL
}

enum BlessingStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  name         String?
  role         Role           @default(CUSTOMER)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  tokens       RefreshToken[]
  websites     Website[]
  orders       Order[]
  notifications Notification[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  templates   Template[]
  createdAt   DateTime   @default(now())
}

model Template {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  thumbnailUrl String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  isPublished Boolean   @default(true)
  defaultData Json?
  websites    Website[]
  createdAt   DateTime  @default(now())
}

model PlanFeature {
  planKey                Plan     @id
  name                   String
  price                  Float    @default(0)
  galleryLimit           Int      @default(5)
  enableMusic            Boolean  @default(false)
  enableWatermarkRemoval Boolean  @default(false)
  enableCustomDomain     Boolean  @default(false)
  enablePrioritySupport  Boolean  @default(false)
  enablePdfDownload      Boolean  @default(false)
  enableMultilang        Boolean  @default(false)
  createdAt              DateTime @default(now())
}

model Website {
  id          String           @id @default(uuid())
  ownerId     String
  owner       User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  templateId  String?
  template    Template?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  domain      String?          @unique
  subdomain   String?          @unique
  status      WebsiteStatus    @default(ACTIVE)
  plan        Plan             @default(STARTER)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  settings    WeddingSettings?
  events      Event[]
  gallery     GalleryItem[]
  rsvps       RSVP[]
  blessings   Blessing[]
  visitors    Visitor[]
  orders      Order[]
}

model WeddingSettings {
  id                        String   @id @default(uuid())
  siteId                    String   @unique
  website                   Website  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  coupleName                String   @default("Rahul & Neha")
  brideName                 String   @default("Neha Sharma")
  groomName                 String   @default("Rahul Verma")
  weddingDate               String   @default("2026-11-25T18:00:00")
  weddingVenue              String   @default("The Grand Palace, New Delhi")
  gateVideo                 String?
  gateTitle                 String?  @default("Wedding Invitation")
  gateSubtitle              String?  @default("Tap to Open & Celebrate")
  musicUrl                  String?
  themeColor                String?  @default("#D4AF37")
  caricatureUrl             String?
  heroBgUrl                 String?
  blessingsCount            Int      @default(0)
  footerCopyright           String?
  enableFloatingPetals      Boolean  @default(true)
  showAdminBtn              Boolean  @default(false)
  invitationCardHeadline    String?  @default("SAVE THE DATE")
  invitationCardSubheadline String?  @default("Together with their families")
  invitationCardFooterNote  String?  @default("Formal invitation to follow")
  data                      Json?
  updatedAt                 DateTime @updatedAt
}

model Event {
  id           String   @id @default(uuid())
  siteId       String
  website      Website  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  eventName    String
  eventDate    String
  eventTime    String?
  venueName    String
  venueAddress String?
  mapLink      String?
  description  String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
}

model GalleryItem {
  id        String   @id @default(uuid())
  siteId    String
  website   Website  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  category  String?  @default("General")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model RSVP {
  id             String   @id @default(uuid())
  siteId         String
  website        Website  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  guestName      String
  guestEmail     String?
  guestPhone     String?
  attending      Boolean  @default(true)
  guestCount     Int      @default(1)
  mealPreference String?
  message        String?
  createdAt      DateTime @default(now())
}

model Blessing {
  id        String         @id @default(uuid())
  siteId    String
  website   Website        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String
  message   String
  status    BlessingStatus @default(APPROVED)
  createdAt DateTime       @default(now())
}

model Visitor {
  id        String   @id @default(uuid())
  siteId    String
  website   Website  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  device    String?
  country   String?  @default("India")
  visitedAt DateTime @default(now())
}

model Order {
  id               String      @id @default(uuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId           String?
  website          Website?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  planKey          Plan
  amount           Float
  currency         String      @default("INR")
  status           OrderStatus @default(PENDING)
  paymentProvider  String      @default("RAZORPAY")
  razorpayOrderId  String?
  razorpayPaymentId String?
  createdAt        DateTime    @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("INFO")
  createdAt DateTime @default(now())
}
